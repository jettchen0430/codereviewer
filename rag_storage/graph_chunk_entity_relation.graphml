    <node id="Insta360">
      <data key="d0">Insta360</data>
      <data key="d1">organization</data>
      <data key="d2">Insta360 is a company known for producing 360-degree cameras and related software, such as their Studio application for viewing panoramic content.&lt;SEP&gt;Insta360 is a company that produces 360-degree cameras and provides software development kits (SDKs) for developers.&lt;SEP&gt;Insta360 is a company that produces 360 cameras, including models like ONE X, ONE X2, X3, and X4.</data>
      <data key="d3">chunk-3b8756d733f712e9cc58b5b2ce82c5f7&lt;SEP&gt;chunk-107aa04d2de1a38c2df49fdb4723753d&lt;SEP&gt;chunk-7c02cbfca3d759f3fc74441722e33b7f</data>
      <data key="d4">README.md&lt;SEP&gt;MediaSDK Demo User Guide zh.md</data>
    </node>
    <node id="CameraSDK-Cpp">
      <data key="d0">CameraSDK-Cpp</data>
      <data key="d1">category</data>
      <data key="d2">CameraSDK-Cpp is a C++ library designed to control Insta360 cameras, offering functionalities like camera discovery, preview, and recording.</data>
      <data key="d3">chunk-7c02cbfca3d759f3fc74441722e33b7f</data>
      <data key="d4">README.md</data>
    </node>
    <node id="ONE X">
      <data key="d0">ONE X</data>
      <data key="d1">category</data>
      <data key="d2">ONE X is a discontinued Insta360 camera model that requires a special firmware upgrade and USB mode settings for SDK control.&lt;SEP&gt;The ONE X is a discontinued 360 camera model from Insta360.</data>
      <data key="d3">chunk-3b8756d733f712e9cc58b5b2ce82c5f7&lt;SEP&gt;chunk-7c02cbfca3d759f3fc74441722e33b7f</data>
      <data key="d4">README.md</data>
    </node>
    <node id="ONE R Twin Edition">
      <data key="d0">ONE R Twin Edition</data>
      <data key="d1">category</data>
      <data key="d2">ONE R Twin Edition is a discontinued Insta360 camera model that requires specific USB mode settings for SDK control.&lt;SEP&gt;The ONE R Twin Edition is a discontinued 360 camera model from Insta360.</data>
      <data key="d3">chunk-3b8756d733f712e9cc58b5b2ce82c5f7&lt;SEP&gt;chunk-7c02cbfca3d759f3fc74441722e33b7f</data>
      <data key="d4">README.md</data>
    </node>
    <node id="ONE X2">
      <data key="d0">ONE X2</data>
      <data key="d1">category</data>
      <data key="d2">ONE X2 is an Insta360 camera model that requires USB mode settings for SDK control.&lt;SEP&gt;The ONE X2 is a current 360 camera model from Insta360.</data>
      <data key="d3">chunk-3b8756d733f712e9cc58b5b2ce82c5f7&lt;SEP&gt;chunk-7c02cbfca3d759f3fc74441722e33b7f</data>
      <data key="d4">README.md</data>
    </node>
