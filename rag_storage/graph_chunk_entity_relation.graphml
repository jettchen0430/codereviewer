      <data key="d1">organization</data>
      <data key="d2">ImageStitcher is a software component used for stitching images, with configurable parameters like input path, stitch type, and output settings.</data>
      <data key="d3">chunk-cf528e8c49e57139843f81256f635dc7</data>
      <data key="d4">README.md</data>
    </node>
    <node id="VideoStitcher">
      <data key="d0">VideoStitcher</data>
      <data key="d1">organization</data>
      <data key="d2">VideoStitcher is a software component for stitching videos, offering features like CUDA acceleration, color enhancement, and progress/error callbacks.</data>
      <data key="d3">chunk-cf528e8c49e57139843f81256f635dc7</data>
      <data key="d4">README.md</data>
    </node>
    <node id="STITCH_TYPE">
      <data key="d0">STITCH_TYPE</data>
      <data key="d1">category</data>
      <data key="d2">STITCH_TYPE is an enumeration defining different stitching algorithms: TEMPLATE (fast but less effective), OPTFLOW (slow but best quality), and DYNAMICSTITCH (balanced).</data>
      <data key="d3">chunk-cf528e8c49e57139843f81256f635dc7</data>
      <data key="d4">README.md</data>
    </node>
    <node id="HDR_TYPE">
      <data key="d0">HDR_TYPE</data>
      <data key="d1">category</data>
      <data key="d2">HDR_TYPE is an enumeration defining HDR processing modes: None, SingleImageHdr, MultiImageHdr_mbb, and MultiImageHdr_mpl.</data>
      <data key="d3">chunk-cf528e8c49e57139843f81256f635dc7</data>
      <data key="d4">README.md</data>
    </node>
    <node id="InputPaths">
      <data key="d0">InputPaths</data>
      <data key="d1">category</data>
      <data key="d2">InputPaths define the source files for stitching, with specific rules for video (max 2 files) and image (multiple paths for HDR).</data>
      <data key="d3">chunk-cf528e8c49e57139843f81256f635dc7</data>
      <data key="d4">README.md</data>
    </node>
    <node id="EnableFlowState">
      <data key="d0">EnableFlowState</data>
      <data key="d1">category</data>
      <data key="d2">Boolean parameter to activate Insta360's proprietary super flowstate feature for enhanced stitching.</data>
      <data key="d3">chunk-cf528e8c49e57139843f81256f635dc7</data>
      <data key="d4">README.md</data>
    </node>
    <node id="EnableDirectionLock">
      <data key="d0">EnableDirectionLock</data>
      <data key="d1">category</data>
      <data key="d2">Boolean parameter to lock the viewing direction during video stitching.</data>
      <data key="d3">chunk-cf528e8c49e57139843f81256f635dc7</data>
      <data key="d4">README.md</data>
    </node>
    <node id="EnableStitchFusion">
      <data key="d0">EnableStitchFusion</data>
      <data key="d1">category</data>
      <data key="d2">Boolean parameter to enable image fusion during the stitching process.</data>
      <data key="d3">chunk-cf528e8c49e57139843f81256f635dc7</data>
      <data key="d4">README.md</data>
    </node>
    <node id="EnableDenoise">
      <data key="d0">EnableDenoise</data>
      <data key="d1">category</data>
      <data key="d2">Boolean parameter to activate noise reduction during video stitching.</data>
      <data key="d3">chunk-cf528e8c49e57139843f81256f635dc7</data>
      <data key="d4">README.md</data>
    </node>
    <node id="EnableColorPlus">
      <data key="d0">EnableColorPlus</data>
      <data key="d1">category</data>
      <data key="d2">Boolean parameter to enable color enhancement with optional model path specification.</data>
      <data key="d3">chunk-cf528e8c49e57139843f81256f635dc7</data>
      <data key="d4">README.md</data>
    </node>
    <node id="process_callback">
      <data key="d0">process_callback</data>
      <data key="d1">category</data>
      <data key="d2">Callback function that reports stitching progress percentage during video processing.</data>
      <data key="d3">chunk-cf528e8c49e57139843f81256f635dc7</data>
      <data key="d4">README.md</data>
    </node>
    <node id="error_callback">
      <data key="d0">error_callback</data>
      <data key="d1">category</data>
