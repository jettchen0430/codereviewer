      <data key="d3">chunk-7c02cbfca3d759f3fc74441722e33b7f</data>
      <data key="d4">README.md</data>
    </node>
    <node id="DeviceDiscovery">
      <data key="d0">DeviceDiscovery</data>
      <data key="d1">category</data>
      <data key="d2">SDK class for detecting and listing available Insta360 cameras.&lt;SEP&gt;The DeviceDiscovery class is responsible for detecting and connecting to cameras to retrieve basic information like serial numbers.</data>
