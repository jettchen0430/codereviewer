    <node id="Windows">
      <data key="d0">Windows</data>
      <data key="d1">category</data>
      <data key="d2">An operating system platform where Visual Studio 2015 is recommended for development.&lt;SEP&gt;Windows is a supported platform for the CameraSDK-Cpp, requiring Windows 7 or later (x64).&lt;SEP&gt;Windows is a supported platform for MediaSDK-Cpp, requiring Windows 7 or later (x64 only).</data>
      <data key="d3">chunk-3b8756d733f712e9cc58b5b2ce82c5f7&lt;SEP&gt;chunk-7c02cbfca3d759f3fc74441722e33b7f&lt;SEP&gt;chunk-10bcc7441e1f7fc8cc8471ac51db9d7c</data>
      <data key="d4">README.md</data>
    </node>
    <node id="Linux">
      <data key="d0">Linux</data>
      <data key="d1">category</data>
      <data key="d2">Linux is a supported platform for MediaSDK-Cpp, primarily tested on Ubuntu.&lt;SEP&gt;Linux is a supported platform for the CameraSDK-Cpp, requiring specific distributions like Ubuntu 18.04, 20.04, or 22.04 (x86_64).</data>
      <data key="d3">chunk-3b8756d733f712e9cc58b5b2ce82c5f7&lt;SEP&gt;chunk-7c02cbfca3d759f3fc74441722e33b7f</data>
      <data key="d4">README.md</data>
    </node>
    <node id="libusb">
      <data key="d0">libusb</data>
      <data key="d1">category</data>
      <data key="d2">libusb is a driver required for Linux systems to detect and control Insta360 cameras via the CameraSDK-Cpp.</data>
      <data key="d3">chunk-7c02cbfca3d759f3fc74441722e33b7f</data>
      <data key="d4">README.md</data>
    </node>
    <node id="libusbK">
