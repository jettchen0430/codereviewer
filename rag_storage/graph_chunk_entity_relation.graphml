      <data key="d0">camera._takePicture</data>
      <data key="d1">category</data>
      <data key="d2">The formal name of the take_picture command in Pro Camera API's response structure.&lt;SEP&gt;camera._takePicture is a command in the Insta360 Pro Camera API used to capture an image.</data>
      <data key="d3">chunk-90835cefa1becc69847978b62c9a10af&lt;SEP&gt;chunk-30f55c23379fa246af6d173ec3cc8323</data>
      <data key="d4">async_command_handling.md&lt;SEP&gt;README.md</data>
    </node>
    <node id="camera._getResult">
      <data key="d0">camera._getResult</data>
      <data key="d1">category</data>
      <data key="d2">The formal name of the get_result command in Pro Camera API's request/response structure.</data>
      <data key="d3">chunk-90835cefa1becc69847978b62c9a10af</data>
      <data key="d4">async_command_handling.md</data>
    </node>
    <node id="res_array">
      <data key="d0">res_array</data>
      <data key="d1">category</data>
      <data key="d2">The response array in get_result command containing results of requested async operations.</data>
      <data key="d3">chunk-90835cefa1becc69847978b62c9a10af</data>
      <data key="d4">async_command_handling.md</data>
    </node>
    <node id="_picUrl">
      <data key="d0">_picUrl</data>
      <data key="d1">category</data>
      <data key="d2">The result field containing image URL in take_picture command response.</data>
      <data key="d3">chunk-90835cefa1becc69847978b62c9a10af</data>
      <data key="d4">async_command_handling.md</data>
    </node>
    <node id="Insta360 Pro">
      <data key="d0">Insta360 Pro</data>
      <data key="d1">organization</data>
      <data key="d2">Insta360 Pro is a 360-degree camera with various resolution capabilities, supporting real-time stitching and 3D output.&lt;SEP&gt;Insta360 Pro is a camera model supported by the Insta360 Pro Camera API, featuring advanced control capabilities via HTTP requests.</data>
      <data key="d3">chunk-70cd8de5774da924ed7695eacebca82b&lt;SEP&gt;chunk-30f55c23379fa246af6d173ec3cc8323</data>
      <data key="d4">capabilities.md&lt;SEP&gt;README.md</data>
    </node>
